{
  "name": "dangerous-inclinations",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "engine",
    "ui",
    "server"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:engine": "turbo run build --filter=@dangerous-inclinations/engine",
    "build:ui": "turbo run build --filter=@dangerous-inclinations/ui",
    "build:server": "turbo run build --filter=@dangerous-inclinations/server",
    "dev": "turbo run dev --filter=@dangerous-inclinations/ui",
    "dev:server": "turbo run dev --filter=@dangerous-inclinations/server",
    "dev:all": "turbo run dev",
    "test": "turbo run test",
    "sim": "turbo run sim --filter=@dangerous-inclinations/engine --",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.6.2",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "yarn@4.12.0"
}
